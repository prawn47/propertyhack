{
  "name": "propertyhack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --outDir frontend-dist",
    "preview": "vite preview",
    "test": "vitest run && cd server && vitest run",
    "test:unit": "vitest run",
    "test:server": "cd server && vitest run",
    "test:integration": "cd server && vitest run --config vitest.integration.config.js",
    "test:e2e": "npx playwright test",
    "test:coverage": "vitest run --coverage && cd server && vitest run --coverage",
    "test:load": "node tests/load/loadTest.js"
  },
  "dependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "framer-motion": "^12.23.24",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "vitest": "^4.0.18"
  }
}
