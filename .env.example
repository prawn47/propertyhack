# Database - PostgreSQL (use Neon for managed, or local Docker)
DATABASE_URL=postgresql://propertyhack:password@localhost:5432/propertyhack

# Redis - for BullMQ job queues
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_ACCESS_SECRET=generate_a_random_64char_string
JWT_REFRESH_SECRET=generate_a_different_64char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3004

# AI - Summarisation (Google Gemini 2.0 Flash)
GEMINI_API_KEY=your_gemini_api_key

# AI - Embeddings (OpenAI text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key

# News Sources
NEWSAPI_API_KEY=your_newsapi_org_key
NEWSAPI_AI_KEY=your_newsapi_ai_key
PERPLEXITY_API_KEY=your_perplexity_api_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@propertyhack.com

# Webhook Security (for newsletter ingest endpoint)
WEBHOOK_SECRET=generate_a_random_string
