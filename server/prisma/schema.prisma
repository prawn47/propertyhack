generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum SourceType {
  RSS
  NEWSAPI_ORG
  NEWSAPI_AI
  PERPLEXITY
  NEWSLETTER
  SCRAPER
  SOCIAL
  MANUAL
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum IngestionLogStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  superAdmin   Boolean  @default(false) @map("super_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model IngestionSource {
  id           String     @id @default(cuid())
  name         String
  type         SourceType
  config       Json
  market       String     @default("AU")
  category     String?
  schedule     String?
  isActive     Boolean    @default(true) @map("is_active")
  lastFetchAt  DateTime?  @map("last_fetch_at")
  lastError    String?    @map("last_error")
  errorCount   Int        @default(0) @map("error_count")
  articleCount Int        @default(0) @map("article_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  articles Article[]
  logs     IngestionLog[]

  @@map("ingestion_sources")
}

model Article {
  id              String                       @id @default(cuid())
  sourceId        String                       @map("source_id")
  sourceUrl       String                       @map("source_url")
  title           String
  slug            String                       @unique
  shortBlurb      String                       @map("short_blurb")
  longSummary     String                       @map("long_summary")
  originalContent String?                      @map("original_content")
  imageUrl        String?                      @map("image_url")
  imageAltText    String?                      @map("image_alt_text")
  category        String
  location        String?
  market          String                       @default("AU")
  markets         String[]                     @default(["AU"])
  isEvergreen     Boolean                      @default(false) @map("is_evergreen")
  status          ArticleStatus                @default(DRAFT)
  isFeatured      Boolean                      @default(false) @map("is_featured")
  viewCount       Int                          @default(0) @map("view_count")
  publishedAt     DateTime?                    @map("published_at")
  metadata        Json?
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  source      IngestionSource @relation(fields: [sourceId], references: [id])
  socialPosts SocialPost[]

  @@index([sourceUrl])
  @@index([status])
  @@index([market])
  @@index([markets])
  @@index([isEvergreen])
  @@index([category])
  @@index([publishedAt])
  @@map("articles")
}

model SocialPost {
  id              String           @id @default(cuid())
  content         String
  imageUrl        String?          @map("image_url")
  platforms       String[]
  platform        String?
  articleId       String?          @map("article_id")
  status          SocialPostStatus @default(DRAFT)
  scheduledFor    DateTime?        @map("scheduled_for")
  publishedAt     DateTime?        @map("published_at")
  platformResults Json?            @map("platform_results")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@map("social_posts")
}

model IngestionLog {
  id            String             @id @default(cuid())
  sourceId      String             @map("source_id")
  status        IngestionLogStatus
  articlesFound Int                @default(0) @map("articles_found")
  articlesNew   Int                @default(0) @map("articles_new")
  errorMessage  String?            @map("error_message")
  duration      Int                @default(0)
  createdAt     DateTime           @default(now()) @map("created_at")

  source IngestionSource @relation(fields: [sourceId], references: [id])

  @@map("ingestion_logs")
}

model Market {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  currency  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("markets")
}

model ArticleCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  market      String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("article_categories")
}

model SystemPrompt {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  content     String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_prompts")
}

model SeoKeyword {
  id        String   @id @default(cuid())
  keyword   String
  location  String?
  category  String?
  volume    String?
  priority  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([location])
  @@index([category])
  @@map("seo_keywords")
}

model LocationSeo {
  id              String   @id @default(cuid())
  location        String   @unique
  slug            String   @unique
  metaTitle       String   @map("meta_title")
  metaDescription String   @map("meta_description")
  h1Title         String   @map("h1_title")
  introContent    String?  @map("intro_content")
  focusKeywords   String[] @map("focus_keywords")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("location_seo")
}
