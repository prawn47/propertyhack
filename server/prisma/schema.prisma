generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum SourceType {
  RSS
  NEWSAPI_ORG
  NEWSAPI_AI
  PERPLEXITY
  NEWSLETTER
  SCRAPER
  SOCIAL
  MANUAL
}

enum ArticleStatus {
  DRAFT        // Just ingested, awaiting summarisation
  SUMMARISING  // In the summarise queue
  SUMMARISED   // Summary complete, ready for image generation
  PUBLISHED    // Live on the site (may have image generation in progress)
  ARCHIVED     // Archived or hidden
}

enum SocialPostStatus {
  DRAFT
  PENDING_APPROVAL
  SCHEDULED
  PUBLISHED
  FAILED
}

enum IngestionLogStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  displayName     String?   @map("display_name")
  superAdmin      Boolean   @default(false) @map("super_admin")
  role            String    @default("user")
  googleId        String?   @unique @map("google_id")
  avatarUrl       String?   @map("avatar_url")
  emailVerified   Boolean   @default(false) @map("email_verified")
  otpCode         String?   @map("otp_code")
  otpExpiresAt    DateTime? @map("otp_expires_at")
  otpPurpose      String?   @map("otp_purpose")
  newsletterOptIn Boolean   @default(false) @map("newsletter_opt_in")
  preferences     Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  savedScenarios SavedScenario[]
  conversations  Conversation[]

  @@map("users")
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String    @db.VarChar(80)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  role           String       @db.VarChar(10)
  content        String
  citations      Json?
  calculatorCall Json?        @map("calculator_call")
  rating         Int?
  tokenCount     Int?         @map("token_count")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum CalculatorType {
  MORTGAGE
  STAMP_DUTY
  RENTAL_YIELD
  BORROWING_POWER
  RENT_VS_BUY
  BUYING_COSTS
}

model SavedScenario {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  name           String
  calculatorType CalculatorType @map("calculator_type")
  market         String         @default("AU")
  inputs         Json
  outputs        Json
  headlineLabel  String         @map("headline_label")
  headlineValue  String         @map("headline_value")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([calculatorType])
  @@index([market])
  @@map("saved_scenarios")
}

model IngestionSource {
  id           String     @id @default(cuid())
  name         String
  type         SourceType
  config       Json
  market       String     @default("AU")
  category     String?
  schedule     String?
  isActive     Boolean    @default(true) @map("is_active")
  lastFetchAt  DateTime?  @map("last_fetch_at")
  lastError    String?    @map("last_error")
  errorCount   Int        @default(0) @map("error_count")
  articleCount Int        @default(0) @map("article_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  articles Article[]
  logs     IngestionLog[]

  @@map("ingestion_sources")
}

model Article {
  id              String                       @id @default(cuid())
  sourceId        String                       @map("source_id")
  sourceUrl       String                       @map("source_url")
  title           String
  slug            String                       @unique
  shortBlurb      String                       @map("short_blurb")
  longSummary     String                       @map("long_summary")
  originalContent String?                      @map("original_content")
  imageUrl        String?                      @map("image_url")
  imageAltText    String?                      @map("image_alt_text")
  category        String
  location        String?
  market          String                       @default("AU")
  markets         String[]                     @default(["AU"])
  isEvergreen     Boolean                      @default(false) @map("is_evergreen")
  isGlobal        Boolean                      @default(false) @map("is_global")
  status          ArticleStatus                @default(DRAFT)
  isFeatured      Boolean                      @default(false) @map("is_featured")
  viewCount       Int                          @default(0) @map("view_count")
  publishedAt     DateTime?                    @map("published_at")
  metadata        Json?
  embedding       Unsupported("vector(1536)")?
  relevanceScore          Int?                         @map("relevance_score")
  contentHash             String?                      @map("content_hash")
  imageGenerationFailed   Boolean                      @default(false) @map("image_generation_failed")
  createdAt               DateTime                     @default(now()) @map("created_at")
  updatedAt               DateTime                     @updatedAt @map("updated_at")

  source      IngestionSource @relation(fields: [sourceId], references: [id])
  socialPosts SocialPost[]

  @@unique([contentHash])
  @@unique([sourceUrl])
  @@index([sourceUrl])
  @@index([status])
  @@index([market])
  @@index([markets])
  @@index([isEvergreen])
  @@index([isGlobal])
  @@index([category])
  @@index([publishedAt])
  @@index([contentHash])
  @@map("articles")
}

model SocialPost {
  id              String           @id @default(cuid())
  content         String
  imageUrl        String?          @map("image_url")
  platforms       String[]
  platform        String?
  headline        String?
  hashtags        String[]
  processedImage  String?          @map("processed_image")
  articleId       String?          @map("article_id")
  status          SocialPostStatus @default(DRAFT)
  scheduledFor    DateTime?        @map("scheduled_for")
  publishedAt     DateTime?        @map("published_at")
  platformResults Json?            @map("platform_results")
  errorReason     String?          @map("error_reason")
  retryCount      Int              @default(0) @map("retry_count")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@map("social_posts")
}

model SocialAccount {
  id            String    @id @default(cuid())
  platform      String    @unique
  accountName   String?   @map("account_name")
  accountId     String?   @map("account_id")
  accessToken   String?   @map("access_token")
  refreshToken  String?   @map("refresh_token")
  tokenExpiry   DateTime? @map("token_expiry")
  isConnected   Boolean   @default(false) @map("is_connected")
  autoPublish   Boolean   @default(true) @map("auto_publish")
  lastError     String?   @map("last_error")
  lastCheckedAt DateTime? @map("last_checked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("social_accounts")
}

model SocialConfig {
  id               String   @id @default(cuid())
  tonePrompt       String   @default("Informative, concise, neutral news tone. Not salesy or clickbaity.") @map("tone_prompt")
  defaultHashtags  String[] @map("default_hashtags")
  minPostGapMins   Int      @default(5) @map("min_post_gap_mins")
  maxDelayMins     Int      @default(60) @map("max_delay_mins")
  fallbackImageUrl String?  @map("fallback_image_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("social_config")
}

model IngestionLog {
  id            String             @id @default(cuid())
  sourceId      String             @map("source_id")
  status        IngestionLogStatus
  articlesFound Int                @default(0) @map("articles_found")
  articlesNew   Int                @default(0) @map("articles_new")
  errorMessage  String?            @map("error_message")
  duration      Int                @default(0)
  createdAt     DateTime           @default(now()) @map("created_at")

  source IngestionSource @relation(fields: [sourceId], references: [id])

  @@map("ingestion_logs")
}

model Market {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  currency  String
  flagEmoji String   @default("") @map("flag_emoji")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("markets")
}

model ArticleCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  market      String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("article_categories")
}

model SystemPrompt {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  content     String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_prompts")
}

model SeoKeyword {
  id        String   @id @default(cuid())
  keyword   String
  market    String?
  location  String?
  category  String?
  volume    String?
  priority  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([market])
  @@index([location])
  @@index([category])
  @@map("seo_keywords")
}

model Subscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  firstName      String    @map("first_name")
  country        String
  region         String
  beehiivSynced  Boolean   @default(false) @map("beehiiv_synced")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([country, region])
  @@map("subscribers")
}

model AiModelConfig {
  id               String   @id @default(uuid())
  task             String   @unique
  provider         String
  model            String
  fallbackProvider String?  @map("fallback_provider")
  fallbackModel    String?  @map("fallback_model")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("ai_model_configs")
}

model LocationSeo {
  id              String   @id @default(cuid())
  location        String   @unique
  slug            String   @unique
  country         String   @default("AU")
  metaTitle       String   @map("meta_title")
  metaDescription String   @map("meta_description")
  h1Title         String   @map("h1_title")
  introContent    String?  @map("intro_content")
  focusKeywords   String[] @map("focus_keywords")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([country])
  @@map("location_seo")
}

enum NewsletterStatus {
  DRAFT
  APPROVED
  SENT
}

enum NewsletterCadence {
  DAILY
  EDITORIAL
  WEEKLY_ROUNDUP
}

model NewsletterDraft {
  id            String              @id @default(uuid())
  jurisdiction  String
  subject       String
  htmlContent   String              @map("html_content")
  textContent   String?             @map("text_content")
  articleIds    String[]            @map("article_ids")
  status        NewsletterStatus    @default(DRAFT)
  cadence       NewsletterCadence   @default(DAILY)
  globalSummary String?             @map("global_summary")
  heroImageUrl  String?             @map("hero_image_url")
  topic         String?
  beehiivPostId String?             @map("beehiiv_post_id")
  generatedAt   DateTime            @default(now()) @map("generated_at")
  approvedAt    DateTime?           @map("approved_at")
  sentAt        DateTime?           @map("sent_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([jurisdiction])
  @@index([status])
  @@index([cadence])
  @@map("newsletter_drafts")
}

model AgentApiKey {
  id         String    @id @default(uuid())
  name       String
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  scopes     String[]
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([keyPrefix])
  @@index([isActive])
  @@map("agent_api_keys")
}

model AgentAuditLog {
  id             String   @id @default(uuid())
  agentKeyName   String   @map("agent_key_name")
  method         String
  path           String
  requestSummary Json?    @map("request_summary")
  responseStatus Int      @map("response_status")
  durationMs     Int      @map("duration_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([agentKeyName])
  @@index([createdAt])
  @@map("agent_audit_logs")
}

model NewsletterGenerationConfig {
  id                      String   @id @default(uuid())
  dailyArticleLimit       Int      @default(20) @map("daily_article_limit")
  editorialArticleLimit   Int      @default(50) @map("editorial_article_limit")
  roundupArticleLimit     Int      @default(30) @map("roundup_article_limit")
  globalArticleLimit      Int      @default(3) @map("global_article_limit")
  historicalLookbackDays  Int      @default(90) @map("historical_lookback_days")
  similarityThreshold     Float    @default(0.4) @map("similarity_threshold")
  editorialMinWordCount   Int      @default(1500) @map("editorial_min_word_count")
  roundupDaysWindow       Int      @default(6) @map("roundup_days_window")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("newsletter_generation_configs")
}
