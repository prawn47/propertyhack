# Database
DATABASE_URL=

# JWT Secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Resend API
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Server Configuration
PORT=3001
NODE_ENV="development"

# CORS Origins
CORS_ORIGIN="http://localhost:3004"

# OpenAI (embeddings)
OPENAI_API_KEY=

# Gemini AI
GEMINI_API_KEY=

# NewsAPI.ai for news curation
NEWSAPI_API_KEY=

# NewsAPI for article fetching
NEWSAPI_KEY=

# NewsAPI.ai (eventregistry.org)
NEWSAPI_AI_KEY=

# Perplexity API
PERPLEXITY_API_KEY=

# Redis (BullMQ job queues)
REDIS_URL=redis://localhost:6379

# Newsletter webhook security
WEBHOOK_SECRET=

# Social token encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SOCIAL_TOKEN_ENCRYPTION_KEY=
